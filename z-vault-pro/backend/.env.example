# Z-Vault Pro — Cloudflare Worker Environment Variables
# Copy this to wrangler.toml [vars] or set secrets via: wrangler secret put <NAME>
#
# PUBLIC VARS (safe for wrangler.toml [vars]):
NETWORK_MODE=testnet                          # testnet | mainnet
NETTS_API_URL=https://netts.io/apiv2
FEEE_API_URL=https://api.feee.io
USDT_CONTRACT_TESTNET=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf
USDT_CONTRACT_MAINNET=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
RELAYER_CONTRACT_TESTNET=TZ2KnAvkher2xBdWk5j6SQvH9Amyoz1pz5
RELAYER_CONTRACT_MAINNET=TXYZ_MAINNET_RELAYER_NOT_DEPLOYED_YET
FEE_THRESHOLD_USDT=5000.00
FEE_TIER_1_USDT=1.00
FEE_TIER_2_USDT=2.00
ACTIVATION_FEE_USDT=2.00
GASFREE_BASE_FEE=0.60                         # Avg Netts.io energy rental cost in USDT
MAINNET_RPC_URL=https://api.trongrid.io

# SECRETS (set via: wrangler secret put <NAME> — NEVER put these in wrangler.toml):
RELAYER_PRIVATE_KEY=your_relayer_wallet_private_key_here
TREASURY_ADDRESS=your_treasury_tron_address_here
NETTS_API_KEY=your_netts_io_api_key_here
VPS_PROXY_URL=https://your-vps-domain.com/rent   # The VPS proxy server URL (HTTPS only)
VPS_SHARED_SECRET=your_random_32char_secret_here  # Must match VPS .env VPS_SHARED_SECRET
