{
  "name": "z-vault-pro-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create z-vault-pro-db",
    "db:migrate": "wrangler d1 execute z-vault-pro-db --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute z-vault-pro-db --local --file=./src/db/schema.sql",
    "types": "wrangler types src/worker-types.d.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250407.0",
    "@types/node": "^22.13.10",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.3",
    "wrangler": "^4.10.0"
  },
  "dependencies": {
    "hono": "^4.7.7",
    "tronweb": "^6.0.0"
  }
}
