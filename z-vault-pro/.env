NETWORK_MODE=testnet

# Relayer wallet private key (MUST have TRX for gas)
RELAYER_PRIVATE_KEY=f28e5958114b3f42e93e71e63c113e77c3f666e1e8fb737399c1cdf0f62ebca2

# TRON Nile Testnet RPC (only used when NETWORK_MODE=testnet)
