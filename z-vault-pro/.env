# USDT TRC20 Contract on Nile Testnet (auto-switches on mainnet)
USDT_CONTRACT=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf

# GasStation Forwarder Contract
# Testnet: THzUZhDbtYHJaSWJFHZ4v5FXfiWCprfUDY
# Mainnet: Deploy a new one and paste the address here
GAS_STATION_CONTRACT=THzUZhDbtYHJaSWJFHZ4v5FXfiWCprfUDY

# TRX Price in USD (for fee calculation)
