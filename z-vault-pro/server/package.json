  "devDependencies": {
    "@types/node": "^22.13.0",
    "esbuild": "^0.27.4",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
