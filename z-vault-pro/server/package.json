{
  "name": "crypxe-relayer",
  "version": "2.0.0",
  "description": "Crypxe Relayer — Gasless USDT Transfer Service with CEO Profit Logging",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
