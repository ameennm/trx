# Z-Vault VPS Proxy — Environment Variables
# Copy this to .env on your VPS server and fill in real values
# NEVER commit the .env file to git

# Shared secret — must match VPS_SHARED_SECRET in Cloudflare Worker secrets
VPS_SHARED_SECRET=change_this_to_a_strong_random_32char_secret

# Netts.io API base URL
NETTS_API_URL=https://netts.io/apiv2

# Port the proxy listens on (Nginx will reverse-proxy HTTPS → this)
PORT=3000
